@startuml
skinparam ClassBackgroundColor white
skinparam ClassBorderColor black
skinparam ClassHeaderBackgroundColor #F0F0F0

package "Domínio de Ensino (Referências)" {
    class "etapas" as ET {
        <color:Crimson>+ id_etapa (PK)</color>
        --
        descricao
    }

    class "multietapas" as MET {
        <color:DarkGreen>+ id_multi_etapa (PK)</color>
        --
        descricao
        <color:Crimson># id_etapa_1 (FK)</color>
        <color:Crimson># id_etapa_2 (FK)</color>
        <color:Crimson># id_etapa_3 (FK)</color>
        <color:Crimson># id_etapa_4 (FK)</color>
        <color:Crimson># id_etapa_5 (FK)</color>
    }
}

package "Camada de Higienização (De-Para)" {
    class "de_para_turmas" as DPT {
        turma_original (Texto sujo: 1° ou 1º)
        <color:Crimson># id_etapas (FK)</color>
        <color:DarkGreen># id_multi_etapas (FK)</color>
        turma_corrigida (Letra)
    }
    
    class "designacoes" as DES {
        escola_nome_bruto
        nome_do_professor
        turma_original
    }
}

package "Core Administrativo" {
    class "escolas" as ESC {
        <color:RoyalBlue>+ id_escola (PK)</color>
        --
        nome_escola
    }

    class "turmas" as T {
        <color:RoyalBlue>+ id_turma (PK)</color>
        --
        <color:RoyalBlue># id_escola (FK)</color>
        <color:Crimson># id_etapa (FK)</color>
        <color:DarkGreen># id_multi_etapa (FK)</color>
        letra_turma
    }

    class "alunos" as AL {
        <color:RoyalBlue>+ id_aluno (PK)</color>
        --
        nome
        cpf
        turma (Texto original)
    }

    class "professores" as PR {
        <color:RoyalBlue>+ profissional_cpf (PK)</color>
        --
        profissional_nome
        profissional_dt_nascimento
        **senha (MD5: DDMMYYYY)**
    }
}

package "Relacionamentos de Enturmação" {
    class "enturmacao_aluno" as EA {
        <color:RoyalBlue># id_aluno (FK)</color>
        <color:RoyalBlue># id_turma (FK)</color>
    }

    class "atribuicao_professor" as AP {
        <color:RoyalBlue># cpf_professor (FK)</color>
        <color:RoyalBlue># id_turma (FK)</color>
    }
}

' Ligações de Integridade
DPT --> ET : "Mapeia para"
DPT --> MET : "Mapeia para"
MET --> ET : "Agrega"
T --> ESC
T --> ET
T --> MET
EA --> AL
EA --> T
AP --> PR
AP --> T

@enduml
