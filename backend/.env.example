DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"
LDAP_URL="ldap://your-ad-server:389"
LDAP_BASE_DN="DC=yourdomain,DC=local"
LDAP_BIND_DN="CN=svc-app,OU=ServiceAccounts,DC=yourdomain,DC=local"
LDAP_BIND_PASSWORD="your-service-account-password"
LDAP_SEARCH_FILTER="(sAMAccountName={{username}})"
LDAP_MOCK="true"
PORT=3001

# Postgres projPiloto — CPF-based fallback authentication
# Used when users log in with CPF + data_nascimento (test environments)
PILOTO_PG_HOST=localhost
PILOTO_PG_PORT=5432
PILOTO_PG_DB=projPiloto
PILOTO_PG_USER=userprojetopiloto
PILOTO_PG_PASSWORD=
