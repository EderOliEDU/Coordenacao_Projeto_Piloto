# ── Aplicação ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (origens permitidas, separadas por vírgula) ────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── JWT ─────────────────────────────────────────────────────────────────────
# Substitua por uma string aleatória longa em produção
JWT_SECRET=troque-por-uma-chave-secreta-forte

# ── Prisma / SQLite ──────────────────────────────────────────────────────────
# Caminho para o arquivo SQLite (relativo ao diretório prisma/ do backend)
DATABASE_URL="file:./dev.db"

# ── PostgreSQL projPiloto (autenticação por CPF + dados escolares) ──────────
PILOTO_PG_HOST=172.17.2.40
PILOTO_PG_PORT=5432
PILOTO_PG_DATABASE=projPiloto
PILOTO_PG_USER=userprojetopiloto
PILOTO_PG_PASSWORD=sua_senha_aqui
# SSL: false | true (rejectUnauthorized=false) | strict (rejectUnauthorized=true)
PILOTO_PG_SSL=false

# ── Admin local (acesso à página de consolidação) ────────────────────────────
# O usuário "admin" faz login com: { "usuario": "admin", "senha": "<ADMIN_PASSWORD>" }
ADMIN_USER=admin
ADMIN_PASSWORD=troque-por-senha-forte
